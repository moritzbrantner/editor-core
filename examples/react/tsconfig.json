{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "declaration": false,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@moritzbrantner/editor-core": ["./src/index.ts"],
      "@moritzbrantner/editor-core/react": ["./src/react.tsx"],
      "@moritzbrantner/editor-core/tree": ["./src/tree.ts"]
    },
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts"]
}
