{
  "name": "@moenarch/editor-core",
  "version": "0.4.1",
  "private": false,
  "description": "Headless shared infrastructure for Moritz Brantner editor packages.",
  "keywords": [
    "editor",
    "headless",
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/moritzbrantner/editor-core#readme",
  "bugs": {
    "url": "https://github.com/moritzbrantner/editor-core/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moritzbrantner/editor-core.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./aspects": {
      "types": "./dist/aspects.d.ts",
      "import": "./dist/aspects.js"
    },
    "./history": {
      "types": "./dist/history.d.ts",
      "import": "./dist/history.js"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "import": "./dist/json.js"
    },
    "./serialization": {
      "types": "./dist/serialization.d.ts",
      "import": "./dist/serialization.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./hotkeys": {
      "types": "./dist/hotkeys.d.ts",
      "import": "./dist/hotkeys.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "import": "./dist/commands.js"
    },
    "./collaboration": {
      "types": "./dist/collaboration.d.ts",
      "import": "./dist/collaboration.js"
    },
    "./constraints": {
      "types": "./dist/constraints.d.ts",
      "import": "./dist/constraints.js"
    },
    "./entities": {
      "types": "./dist/entities.d.ts",
      "import": "./dist/entities.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./indexes": {
      "types": "./dist/indexes.d.ts",
      "import": "./dist/indexes.js"
    },
    "./interaction": {
      "types": "./dist/interaction.d.ts",
      "import": "./dist/interaction.js"
    },
    "./operations": {
      "types": "./dist/operations.d.ts",
      "import": "./dist/operations.js"
    },
    "./persistence": {
      "types": "./dist/persistence.d.ts",
      "import": "./dist/persistence.js"
    },
    "./patches": {
      "types": "./dist/patches.d.ts",
      "import": "./dist/patches.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js"
    },
    "./selection": {
      "types": "./dist/selection.d.ts",
      "import": "./dist/selection.js"
    },
    "./share": {
      "types": "./dist/share.d.ts",
      "import": "./dist/share.js"
    },
    "./sync": {
      "types": "./dist/sync.d.ts",
      "import": "./dist/sync.js"
    },
    "./tree": {
      "types": "./dist/tree.d.ts",
      "import": "./dist/tree.js"
    },
    "./viewport": {
      "types": "./dist/viewport.d.ts",
      "import": "./dist/viewport.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "architecture:report": "node scripts/check-architecture.mjs --report",
    "architecture:check": "node scripts/check-architecture.mjs --check",
    "lint": "oxlint src stories benchmarks tests scripts .storybook examples/react/src examples/react/vite.config.ts playwright.config.ts unlighthouse.config.ts vitest.storybook.config.ts vitest.config.ts --format=github",
    "check-types": "tsc --noEmit",
    "test": "bun run test:unit",
    "test:coverage": "$(dirname $(command -v npm))/node node_modules/vitest/vitest.mjs run --coverage",
    "test:unit": "$(dirname $(command -v npm))/node node_modules/vitest/vitest.mjs run && $(dirname $(command -v npm))/node --test scripts/*.test.mjs",
    "test:react": "$(dirname $(command -v npm))/node node_modules/vitest/vitest.mjs run src/react.test.tsx",
    "test:integration": "bun run build && bun run smoke:package && node scripts/check-api-snapshot.mjs",
    "test:e2e": "bun run example:build && bun run test:e2e:run",
    "test:e2e:run": "playwright test",
    "build": "tsup src/index.ts src/aspects.ts src/history.ts src/json.ts src/serialization.ts src/testing.ts src/hotkeys.ts src/browser.ts src/commands.ts src/collaboration.ts src/constraints.ts src/entities.ts src/indexes.ts src/interaction.ts src/operations.ts src/persistence.ts src/patches.ts src/plugins.ts src/runtime.ts src/selection.ts src/share.ts src/sync.ts src/tree.ts src/viewport.ts src/react.tsx --format esm --dts --clean --out-dir dist",
    "example:dev": "vite --config examples/react/vite.config.ts --host 0.0.0.0",
    "example:check-types": "tsc -p examples/react/tsconfig.json --noEmit",
    "example:build": "vite build --config examples/react/vite.config.ts",
    "example:preview": "vite preview --config examples/react/vite.config.ts --host 0.0.0.0",
    "storybook": "storybook dev --port 6006 --host 0.0.0.0",
    "storybook:build": "storybook build --output-dir storybook-static",
    "test:storybook": "bun run test:storybook:run",
    "test:storybook:ci": "bun run test:storybook:run",
    "test:storybook:run": "$(dirname $(command -v npm))/node node_modules/vitest/vitest.mjs --config vitest.storybook.config.ts run",
    "unlighthouse": "bun run example:build && bun run unlighthouse:ci",
    "unlighthouse:ci": "start-server-and-test \"bun run example:preview -- --port 4173\" http://127.0.0.1:4173 \"bun run unlighthouse:scan\"",
    "unlighthouse:scan": "unlighthouse-ci --site http://127.0.0.1:4173 --config-file unlighthouse.config.ts",
    "bench": "$(dirname $(command -v npm))/node node_modules/vitest/vitest.mjs bench --run",
    "bench:check": "node scripts/run-benchmark-baseline-check.mjs",
    "test:stable": "bun run build && $(dirname $(command -v npm))/node scripts/run-stable-comparison.mjs",
    "api:check": "bun run build && node scripts/check-api-snapshot.mjs",
    "api:update": "bun run build && node scripts/check-api-snapshot.mjs --write",
    "size:check": "bun run build && bun run pack:check",
    "smoke:package": "node scripts/smoke-package-exports.mjs",
    "pack:check": "bun pm pack --dry-run",
    "prepublishOnly": "bun run verify:release",
    "verify:fast": "bun run format:check && bun run architecture:check && bun run lint && bun run check-types && bun run test:unit",
    "verify:release": "bun run verify:fast && bun run example:check-types && bun run test:integration && bun run test:e2e && bun run storybook:build && bun run bench:check && bun run unlighthouse && bun run pack:check",
    "verify:ci": "bun run verify:release",
    "verify": "bun run verify:release"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5.101.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "start-server-and-test": "3.0.8",
    "storybook": "^10.4.2",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "unlighthouse": "^0.17.9",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "bun@1.3.14"
}
