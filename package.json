{
  "name": "@moritzbrantner/editor-core",
  "version": "0.1.0",
  "private": false,
  "homepage": "https://github.com/moritzbrantner/editor-core#readme",
  "bugs": {
    "url": "https://github.com/moritzbrantner/editor-core/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moritzbrantner/editor-core.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./aspects": {
      "types": "./dist/aspects.d.ts",
      "import": "./dist/aspects.js"
    },
    "./history": {
      "types": "./dist/history.d.ts",
      "import": "./dist/history.js"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "import": "./dist/json.js"
    },
    "./serialization": {
      "types": "./dist/serialization.d.ts",
      "import": "./dist/serialization.js"
    },
    "./hotkeys": {
      "types": "./dist/hotkeys.d.ts",
      "import": "./dist/hotkeys.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "import": "./dist/commands.js"
    },
    "./share": {
      "types": "./dist/share.d.ts",
      "import": "./dist/share.js"
    },
    "./tree": {
      "types": "./dist/tree.d.ts",
      "import": "./dist/tree.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint src scripts examples/react/src examples/react/vite.config.ts vitest.config.ts --format=github",
    "check-types": "tsc --noEmit",
    "test": "$(dirname $(command -v npm))/node node_modules/vitest/vitest.mjs run",
    "build": "tsup src/index.ts src/aspects.ts src/history.ts src/json.ts src/serialization.ts src/hotkeys.ts src/browser.ts src/commands.ts src/share.ts src/tree.ts src/react.tsx --format esm --dts --clean --out-dir dist",
    "example:dev": "vite --config examples/react/vite.config.ts --host 0.0.0.0",
    "example:check-types": "tsc -p examples/react/tsconfig.json --noEmit",
    "example:build": "vite build --config examples/react/vite.config.ts",
    "example:preview": "vite preview --config examples/react/vite.config.ts --host 0.0.0.0",
    "smoke:package": "node scripts/smoke-package-exports.mjs",
    "pack:check": "bun pm pack --dry-run",
    "verify": "bun run format:check && bun run lint && bun run check-types && bun run example:check-types && bun run test && bun run build && bun run smoke:package && bun run pack:check && bun run example:build"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5.101.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "packageManager": "bun@1.3.14"
}
